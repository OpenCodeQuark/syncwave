APP_NAME=SyncWave Signaling Server
APP_VERSION=1.1.4
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WEBSOCKET_PATH=/ws
PROTOCOL_VERSION=1
REQUIRE_SERVER_CONNECTION_PIN=false
# Exactly 8 digits when REQUIRE_SERVER_CONNECTION_PIN=true.
SERVER_CONNECTION_PIN=
REDIS_URL=
ROOM_TTL_SECONDS=21600
MAX_PARTICIPANTS_PER_ROOM=20
PIN_HASH_SECRET=change-this-in-production
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO
GITHUB_REDIRECT=https://github.com/OpenCodeQuark/syncwave
